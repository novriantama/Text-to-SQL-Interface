# Application Environment Variables
APP_ENV=development
LOG_LEVEL=INFO
SECRET_KEY=change-this-in-production-secret-key-32-chars

# Database Configuration (PostgreSQL / DuckDB / SQLite)
DB_DRIVER=postgresql
READONLY_DB_URI=postgresql://text_sql_admin:admin_password@localhost:5432/text_to_sql_db

# OpenAgentic & Claude Sonnet 4.6 LLM Provider Configuration
LLM_PROVIDER=openagentic
OPENAGENTIC_API_KEY=your_api_key
OPENAGENTIC_BASE_URL=https://openagentic.id/api/v1
OPENAGENTIC_MODEL=claude-sonnet-4.6

# Guardrails Configuration
MAX_ROW_LIMIT=1000
MAX_SUBQUERY_DEPTH=3
MAX_EXPLAIN_COST=50000.0

# Vector Store Configuration
VECTOR_SIMILARITY_THRESHOLD=0.35
