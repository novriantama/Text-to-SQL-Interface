# Application Environment Variables
APP_ENV=development
LOG_LEVEL=INFO
SECRET_KEY=change-this-in-production-secret-key-32-chars

# Database Configuration (PostgreSQL / DuckDB)
DB_DRIVER=postgresql
DB_HOST=localhost
DB_PORT=5432
DB_NAME=text_to_sql_db
DB_USER=readonly_user
DB_PASSWORD=readonly_password
READONLY_DB_URI=postgresql://readonly_user:readonly_password@localhost:5432/text_to_sql_db

# LLM Providers Configuration
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
OPENAI_API_KEY=sk-proj-your-openai-api-key
OPENAI_MODEL=gpt-4o

# Guardrails Configuration
MAX_ROW_LIMIT=1000
MAX_SUBQUERY_DEPTH=3
MAX_EXPLAIN_COST=50000.0

# Vector Store Configuration
VECTOR_SIMILARITY_THRESHOLD=0.35
